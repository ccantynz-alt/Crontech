# Enforce LF line endings for all text files (Biome formatter requires LF)
* text=auto eol=lf

# Explicitly mark binary files as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.tgz binary
*.zip binary
*.tar binary
*.gz binary
*.lock binary
