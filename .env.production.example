# ============================================================================
# Crontech Platform — Production Environment Variables
# ============================================================================
#
# Copy to .env.production and fill in your values:
#   cp .env.production.example .env.production
#
# Generate secrets with:
#   openssl rand -hex 32
#
# NEVER commit .env.production to git.
# ============================================================================


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ DOMAIN & DEPLOYMENT                                                      │
# └──────────────────────────────────────────────────────────────────────────┘

# The apex domain. Used to derive api.DOMAIN, www.DOMAIN, etc.
# All docker-compose service URLs are computed from this single variable.
CRONTECH_DOMAIN=crontech.ai

# Git commit SHA — set by CI/CD at deploy time. Baked into the client
# bundle and exposed via /api/version for post-deploy smoke tests.
# Override at deploy time: GIT_SHA=$(git rev-parse HEAD) docker compose up -d
GIT_SHA=unknown

# Email for Let's Encrypt certificate expiry notifications.
# Caddy uses this for automatic HTTPS.
ACME_EMAIL=admin@crontech.ai


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ AUTH SECRETS (CRITICAL — generate unique values per environment)          │
# └──────────────────────────────────────────────────────────────────────────┘

# Session signing secret. Used for cookie-based session tokens.
# Generate: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME

# JWT signing secret. Used for stateless API tokens.
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ WEBAUTHN / PASSKEYS                                                      │
# └──────────────────────────────────────────────────────────────────────────┘
# These are derived from CRONTECH_DOMAIN inside docker-compose.
# Override here ONLY if your Relying Party ID differs from the domain (rare).
# WEBAUTHN_RP_ID=crontech.ai
# WEBAUTHN_RP_NAME=Crontech
# WEBAUTHN_ORIGIN=https://crontech.ai


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ GOOGLE OAUTH 2.0                                                         │
# └──────────────────────────────────────────────────────────────────────────┘
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Set authorized redirect URI to: https://api.crontech.ai/auth/google/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ DATABASE                                                                 │
# └──────────────────────────────────────────────────────────────────────────┘

# Primary database URL. Used by the API for reads/writes.
# For Turso: set TURSO_DATABASE_URL and TURSO_AUTH_TOKEN instead.
# For local SQLite fallback (no external DB): file:/data/crontech.db
DATABASE_URL=file:/data/crontech.db

# Turso (primary edge SQLite — recommended for production)
# Sign up at: https://turso.tech
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Neon (serverless PostgreSQL — complex queries, full Postgres power)
# Sign up at: https://neon.tech
# Only needed if features depend on Postgres. Can be blank for Phase 1.
NEON_DATABASE_URL=


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ QDRANT (VECTOR DATABASE)                                                 │
# └──────────────────────────────────────────────────────────────────────────┘
# Qdrant URL is hardcoded to http://qdrant:6333 in docker-compose (internal
# Docker DNS). No need to set it here. Only set the API key if you enable
# Qdrant authentication.

QDRANT_API_KEY=


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ AI                                                                       │
# └──────────────────────────────────────────────────────────────────────────┘
# AI features degrade gracefully if these are blank.
# Get keys at:
#   Anthropic: https://console.anthropic.com/settings/keys
#   OpenAI:    https://platform.openai.com/api-keys

ANTHROPIC_API_KEY=
OPENAI_API_KEY=


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ STRIPE (BILLING)                                                         │
# └──────────────────────────────────────────────────────────────────────────┘
# https://dashboard.stripe.com/apikeys
# Webhook endpoint: https://api.crontech.ai/webhooks/stripe

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ EMAIL                                                                    │
# └──────────────────────────────────────────────────────────────────────────┘

# AlecRae MTA (primary — self-hosted mail infrastructure)
ALECRAE_API_URL=
ALECRAE_API_KEY=

# Resend (fallback — used until AlecRae MTA is live)
# Sign up at: https://resend.com
RESEND_API_KEY=

# Sender address for transactional emails
EMAIL_FROM=noreply@crontech.ai


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ OBSERVABILITY (optional — activate with --profile observability)          │
# └──────────────────────────────────────────────────────────────────────────┘

# When observability profile is active, the API auto-connects to the OTel
# collector via Docker DNS. Set this to override with an external collector.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Grafana admin credentials (only used when observability profile is active)
# CRITICAL: Change the password before exposing Grafana publicly.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ SENTINEL (COMPETITIVE INTELLIGENCE — optional)                           │
# └──────────────────────────────────────────────────────────────────────────┘
# Sentinel features degrade gracefully without these.

# Slack incoming webhook for competitive intelligence alerts
SLACK_WEBHOOK_URL=

# Discord webhook for backup alerting
DISCORD_WEBHOOK_URL=

# GitHub Personal Access Token for release monitoring
# Create at: https://github.com/settings/tokens (read-only public_repo scope)
GITHUB_TOKEN=


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ ORCHESTRATOR (internal — no change needed)                               │
# └──────────────────────────────────────────────────────────────────────────┘
# Internal port for the deploy control plane. Override only if port 9000
# conflicts with another service on the same Docker network.
# ORCHESTRATOR_PORT=9000
