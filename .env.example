# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Neon Serverless PostgreSQL ─────────────────────────────────────────
NEON_DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/dbname?sslmode=require

# ── Qdrant Vector Database ────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key

# ── AI Provider ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ── WebAuthn / Passkeys ────────────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Back to the Future

# ── Public API URL (accessible from the browser) ──────────────────────
PUBLIC_API_URL=http://localhost:3001

# ── OpenTelemetry ─────────────────────────────────────────────────────
OTEL_SERVICE_NAME=back-to-the-future-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Enterprise SSO ─────────────────────────────────────────────────────
SSO_PROVIDER=oidc
SSO_ISSUER_URL=https://your-idp.example.com
SSO_CLIENT_ID=your-sso-client-id
SSO_CLIENT_SECRET=your-sso-client-secret
SSO_CALLBACK_URL=http://localhost:3001/api/sso/callback
