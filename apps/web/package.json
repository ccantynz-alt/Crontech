{
  "name": "@back-to-the-future/web",
  "type": "module",
  "scripts": {
    "dev": "vinxi dev --port 3000",
    "build": "vinxi build",
    "start": "vinxi start",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format . --write",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:visual": "playwright test visual-regression",
    "e2e:a11y": "playwright test accessibility",
    "e2e:update-snapshots": "playwright test --update-snapshots",
    "e2e:chromium": "playwright test --project=chromium",
    "e2e:firefox": "playwright test --project=firefox",
    "e2e:webkit": "playwright test --project=webkit",
    "e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari"
  },
  "dependencies": {
    "@back-to-the-future/ai-core": "workspace:*",
    "@back-to-the-future/schemas": "workspace:*",
    "@back-to-the-future/ui": "workspace:*",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.3",
    "@solidjs/start": "^1.1.0",
    "@tailwindcss/vite": "4.2.2",
    "@solid-primitives/i18n": "^2.1.1",
    "solid-js": "^1.9.5",
    "tailwindcss": "4.2.2",
    "vinxi": "^0.5.3",
    "y-protocols": "^1",
    "y-websocket": "^2",
    "yjs": "^13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@types/node": "^22.13.0",
    "@playwright/test": "^1.52.0",
    "typescript": "^5.7.3"
  }
}
